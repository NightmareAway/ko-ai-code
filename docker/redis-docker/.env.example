# Redis 镜像版本 (推荐使用最新的稳定版，如 7.2 或 7.4)
REDIS_VERSION=7.4

# 映射到宿主机的端口 (如果需要避免冲突，可以修改为其他端口，如 16379)
REDIS_PORT=6379

# Redis 访问密码 (生产环境请务必设置强密码)
REDIS_PASSWORD=YourStrongPasswordHere

# 宿主机上 Redis 数据持久化的存储目录
REDIS_DATA_DIR=./redis-data

# 宿主机上 Redis 挂载的自定义配置文件（可选，如有自定义需求）
REDIS_CONF_DIR=./redis-conf

# Redis 实例最大内存限制
REDIS_MAX_MEMORY=512mb

# Redis 内存淘汰策略 (常用策略: allkeys-lru, volatile-lru, noeviction)
REDIS_MAX_MEMORY_POLICY=allkeys-lru
